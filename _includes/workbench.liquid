<div class="workbench-dashboard mb-4">
  <div class="d-flex flex-wrap gap-2 mb-4" role="group" aria-label="Filter by category">
    <button
      type="button"
      class="btn btn-sm btn-primary workbench-filter"
      data-category="All"
      aria-pressed="true"
    >
      All
    </button>
    <button
      type="button"
      class="btn btn-sm btn-outline-primary workbench-filter"
      data-category="Research"
      aria-pressed="false"
    >
      Research
    </button>
    <button
      type="button"
      class="btn btn-sm btn-outline-primary workbench-filter"
      data-category="Education"
      aria-pressed="false"
    >
      Education
    </button>
    <button
      type="button"
      class="btn btn-sm btn-outline-primary workbench-filter"
      data-category="Utility"
      aria-pressed="false"
    >
      Utility
    </button>
  </div>

  {% if site.data.workbench %}
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 gx-2 gx-md-3">
      {% for item in site.data.workbench %}
        <div class="col workbench-item" data-category="{{ item.category | escape }}">
          <div class="card h-100 shadow-sm border workbench-card">
            <div class="card-body d-flex flex-column">
              <div class="mb-2 text-center text-muted">
                <i class="{{ item.icon }} fa-2x" aria-hidden="true"></i>
              </div>
              <h2 class="card-title h5 text-center">{{ item.title }}</h2>
              <p class="card-text text-muted small flex-grow-1">{{ item.description }}</p>
              <p class="mb-0 text-center">
                <span class="badge rounded-pill bg-secondary">{{ item.target }}</span>
              </p>
            </div>
            <div class="card-footer bg-transparent border-top-0 text-center pb-3">
              <a
                class="btn btn-primary btn-sm"
                href="{{ item.url }}"
                target="_blank"
                rel="noopener noreferrer"
              >
                Launch app
              </a>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p class="text-muted">No workbench items configured.</p>
  {% endif %}
</div>

<script>
  (function () {
    var filters = document.querySelectorAll('.workbench-filter');
    var items = document.querySelectorAll('.workbench-item');
    if (!filters.length || !items.length) return;

    function setActive(button) {
      for (var i = 0; i < filters.length; i++) {
        filters[i].classList.remove('btn-primary', 'active');
        filters[i].classList.add('btn-outline-primary');
        filters[i].setAttribute('aria-pressed', 'false');
      }
      button.classList.add('btn-primary', 'active');
      button.classList.remove('btn-outline-primary');
      button.setAttribute('aria-pressed', 'true');
    }

    function applyFilter(category) {
      for (var j = 0; j < items.length; j++) {
        var col = items[j];
        var cat = col.getAttribute('data-category');
        if (category === 'All' || cat === category) {
          col.style.display = '';
        } else {
          col.style.display = 'none';
        }
      }
    }

    for (var k = 0; k < filters.length; k++) {
      filters[k].addEventListener('click', function () {
        var cat = this.getAttribute('data-category');
        setActive(this);
        applyFilter(cat);
      });
    }
  })();
</script>
